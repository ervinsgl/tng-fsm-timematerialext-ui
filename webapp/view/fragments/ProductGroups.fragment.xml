<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!-- 
        ProductGroups Fragment: Displays activities grouped by product.
        
        Structure per group:
        - Panel header: Product description + SO Item ID + activity count
        - Per activity: Toolbar (code, subject, T&M buttons) + T&M tables
        - Three table types: Time/Material, Expense, Mileage (filtered by type config)
        - Tables support inline edit mode, row selection, sort, and batch operations
        
        Model: view>/productGroups
    -->
    <VBox class="sapUiResponsiveMargin">
    
        <!-- Empty State - No Activities for User's Org Level -->
        <IllustratedMessage
            illustrationType="sapIllus-NoEntries"
            title="{= ${view>/noActivitiesMessage/show} ? ${view>/noActivitiesMessage/title} : ${i18n>productGroupsNoActivitiesTitle}}"
            description="{= ${view>/noActivitiesMessage/show} ? ${view>/noActivitiesMessage/description} : ${i18n>productGroupsNoActivitiesDesc}}"
            visible="{= ${view>/productGroups}.length === 0 }"
        >
            <additionalContent>
                <Button text="{i18n>productGroupsRefresh}" type="Emphasized" icon="sap-icon://refresh" press=".onRefresh"/>
            </additionalContent>
        </IllustratedMessage>
        
        <!-- Product Groups List -->
        <List items="{view>/productGroups}" mode="None" showSeparators="None" visible="{= ${view>/productGroups}.length > 0 }">
            <CustomListItem type="Inactive">
                <Panel expandable="true" expanded="{view>expanded}" expand="onProductPanelExpand" class="productGroupPanel">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://product" class="sapUiSmallMarginEnd"/>
                            <Title text="{i18n>productGroupsProduct} {view>productDescription}" wrapping="true"/>
                            <ToolbarSpacer/>
                            <Text text="{i18n>serviceOrderId} {view>soItemId}" class="sapUiTinyMarginEnd"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <Toolbar design="Transparent" height="2rem">
                            <Label text="{view>activityCount} {i18n>productGroupsActivities}" design="Bold"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{view>tmTotalCount}" unit="{i18n>productGroupsTMEntries}" state="Information"/>
                        </Toolbar>
                        
                        <List items="{path: 'view>activities', templateShareable: false}" mode="None" showSeparators="None" growing="true" growingThreshold="20">
                            <CustomListItem type="Inactive" class="activityListItem">
                                <Panel expandable="true" expanded="{view>detailsExpanded}" class="activityEntryPanel">
                                    <customData>
                                        <core:CustomData key="highlighted" value="{view>entryActivityFlag}" writeToDom="true"/>
                                        <core:CustomData key="activitystatus" value="{view>status}" writeToDom="true"/>
                                    </customData>
                                    <headerToolbar>
                                        <OverflowToolbar design="Info" class="activityHeaderToolbar">
                                            <core:Icon src="sap-icon://activity-individual" class="sapUiSmallMarginEnd"/>
                                            <Title text="ID: {view>externalId}" level="H5" class="sapUiSmallMarginEnd activityHeaderId"/>
                                            <Title text="{view>subject}" level="H5" wrapping="true" class="activityHeaderSubject"/>
                                        </OverflowToolbar>
                                    </headerToolbar>
                                    <content>
                                        <Toolbar design="Info" class="activitySubjectBar sapUiTinyMarginBottom">
                                            <Title text="{view>code}" level="H6"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus text="{view>status}" state="{view>statusState}" class="sapUiTinyMarginEnd"/>
                                            <ObjectStatus text="{view>executionStage}" state="{view>stageState}"/>
                                        </Toolbar>
                                        
                                        <HBox class="activityEntryContent">
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityServiceProduct}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>serviceProductDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityResponsible}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>responsibleDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityTechnicians}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>techniciansDisplayText}" class="activityFieldValue" wrapping="true"/>
                                                </HBox>
                                            </VBox>
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityAddress}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>addressFull}" class="activityFieldValue" wrapping="true"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityOrgLevel}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>orgLevelDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityItemType}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>itemTypeCode}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityPlannedStart}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedStartDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityPlannedEnd}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedEndDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="{i18n>activityDuration}" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedDuration}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                        </HBox>
                                        
                                        <!-- T&M REPORTS SECTION -->
                                        <VBox class="tmTablesSection sapUiSmallMarginTop">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom sapUiSmallMarginBegin">
                                                <core:Icon src="sap-icon://timesheet" class="sapUiTinyMarginEnd"/>
                                                <Label text="{i18n>activityTMReports}" design="Bold"/>
                                                <ObjectNumber number="{view>tmReportsCount}" unit="{i18n>activityItemsUnit}" state="{= ${view>tmReportsCount} > 0 ? 'Success' : 'None'}" class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                            
                                            <!-- T&M Summary Stats - Only show for Time & Material activities (not expense/mileage) -->
                                            <HBox visible="{= ${view>tmReportsLoaded} &amp;&amp; ${view>isTimeMaterialType} }" class="sapUiTinyMarginBottom sapUiSmallMarginBegin" wrap="Wrap">
                                                <VBox class="sapUiSmallMarginEnd" visible="{= ${view>quantity} > 0 }">
                                                    <Label text="{i18n>activityMaterial}"/>
                                                    <HBox alignItems="Center">
                                                        <ObjectNumber number="{path: 'view>tmMaterialQtyReported', formatter: '.formatter.formatQuantity'}" state="{= ${view>tmMaterialQtyReported} > 0 ? 'Information' : 'None'}"/>
                                                        <Text text=" / " class="sapUiTinyMarginBeginEnd"/>
                                                        <Text text="{path: 'view>quantity', formatter: '.formatter.formatQuantity'}"/>
                                                    </HBox>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="{i18n>activityArbeitszeit}"/>
                                                    <ObjectNumber number="{view>tmAzHoursReported}" unit="{i18n>activityHoursUnit}" state="{= ${view>tmAzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="{i18n>activityFahrzeit}"/>
                                                    <ObjectNumber number="{view>tmFzHoursReported}" unit="{i18n>activityHoursUnit}" state="{= ${view>tmFzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                                <VBox>
                                                    <Label text="{i18n>activityWartezeit}"/>
                                                    <ObjectNumber number="{view>tmWzHoursReported}" unit="{i18n>activityHoursUnit}" state="{= ${view>tmWzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                            </HBox>
                                            
                                            <!-- TIME & MATERIAL TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= (${view>tmTimeEffortCount} + ${view>tmMaterialCount}) > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://time-entry-request" class="sapUiTinyMarginEnd"/>
                                                        <Title text="{i18n>tmTimeEffortMaterial}" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://hint" type="Transparent" press=".onShowStatusLegend" tooltip="{i18n>tmStatusLegendTooltip}" class="sapUiTinyMarginBegin"/>
                                                        <SegmentedButton selectedKey="ALL" selectionChange=".onTMTypeFilterChange">
                                                            <items>
                                                                <SegmentedButtonItem key="ALL" text="{i18n>tmFilterAll}"/>
                                                                <SegmentedButtonItem key="Time Effort" icon="sap-icon://time-entry-request" tooltip="{i18n>tooltipTimeEffort}"/>
                                                                <SegmentedButtonItem key="Material" icon="sap-icon://product" tooltip="{i18n>tooltipMaterial}"/>
                                                            </items>
                                                        </SegmentedButton>
                                                        <Button icon="sap-icon://sort" press=".onOpenSortDialog" tooltip="{i18n>tmSortByTooltip}" class="sapUiTinyMarginBegin">
                                                            <customData>
                                                                <core:CustomData key="tableType" value="TM"/>
                                                            </customData>
                                                        </Button>
                                                        <Button text="{i18n>tmEditSelected}" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>tmEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmDeleteSelected}" icon="sap-icon://delete" type="Reject" press=".onDeleteSelectedTM" visible="{= ${view>tmEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmSaveAll}" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>tmEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmEndEdit}" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>tmEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmAddEntry}" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectStatus 
                                                            text="{= ${view>isCancelled} ? ${i18n>activityCancelled} : ${i18n>activityClosed}}" 
                                                            state="{= ${view>isCancelled} ? 'Error' : 'None'}" 
                                                            icon="{= ${view>isCancelled} ? 'sap-icon://decline' : 'sap-icon://locked'}"
                                                            visible="{= ${view>isReadOnly} === true}"
                                                            class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{= ${view>tmTimeEffortCount} + ${view>tmMaterialCount} }" unit="{i18n>tmEntriesUnit}" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'NE', value1: 'Expense' }, { path: 'type', operator: 'NE', value1: 'Mileage' }], sorter: { path: 'sortDate', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="{i18n>tmColStatus}"/></Column>
                                                                <Column width="8rem" hAlign="Begin"><Text text="{i18n>tmColDescription}"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="{i18n>tmColTechnician}"/></Column>
                                                                <Column width="6.5rem" hAlign="Begin"><Text text="{i18n>tmColTime}"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="{i18n>tmColQty}"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColDate}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColDecision}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColRemarks}"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'DECLINED_CLOSED' || ${view>decisionStatus} === 'CANCELLED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <core:Icon src="{= ${view>type} === 'Time Effort' ? 'sap-icon://time-entry-request' : 'sap-icon://product'}" color="{= ${view>type} === 'Time Effort' ? '#0854A0' : '#107E3E'}" tooltip="{view>type}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'REJECTED' : ${view>decisionStatus}}" state="{view>decisionStatusState}"/>
                                                                        <Text text="{= ${view>type} === 'Time Effort' ? ${view>taskDisplayText} : ${view>itemDisplayText}}" wrapping="false"/>
                                                                        <Text text="{view>createPersonDisplayText}" wrapping="false"/>
                                                                        <!-- Time: show StepInput for Time Effort (in hours), N/A for Material -->
                                                                        <StepInput value="{view>durationHrs}" min="0" step="0.25" displayValuePrecision="2" width="5rem" editable="{view>editMode}" visible="{= ${view>type} === 'Time Effort'}"/>
                                                                        <Text text="{path: 'view>type', formatter: '.formatter.formatHoursUnit'}"/>
                                                                        <!-- Qty: show Input for Material, N/A for Time Effort -->
                                                                        <Input value="{view>quantity}" type="Number" width="4rem" editable="{view>editMode}" visible="{= ${view>type} === 'Material'}"/>
                                                                        <Text text="{path: 'view>type', formatter: '.formatter.formatPiecesUnit'}"/>
                                                                        <!-- Date: editable DatePicker in edit mode -->
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="8rem" editable="{view>editMode}" maxDate="{path: 'view>entryDateFormatted', formatter: '.formatter.formatTodayMaxDate'}"/>
                                                                        <Text text="{view>decisionRemarks}" wrapping="true"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- EXPENSES TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= ${view>tmExpenseCount} > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd" color="#E9730C"/>
                                                        <Title text="{i18n>tmExpenses}" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://hint" type="Transparent" press=".onShowStatusLegend" tooltip="{i18n>tmStatusLegendTooltip}" class="sapUiTinyMarginBegin"/>
                                                        <Button icon="sap-icon://sort" press=".onOpenSortDialog" tooltip="{i18n>tmSortByTooltip}" class="sapUiTinyMarginBegin">
                                                            <customData>
                                                                <core:CustomData key="tableType" value="Expense"/>
                                                            </customData>
                                                        </Button>
                                                        <Button text="{i18n>tmEditSelected}" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>expenseEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmDeleteSelected}" icon="sap-icon://delete" type="Reject" press=".onDeleteSelectedTM" visible="{= ${view>expenseEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmSaveAll}" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>expenseEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmEndEdit}" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>expenseEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmAddEntry}" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectStatus 
                                                            text="{= ${view>isCancelled} ? ${i18n>activityCancelled} : ${i18n>activityClosed}}" 
                                                            state="{= ${view>isCancelled} ? 'Error' : 'None'}" 
                                                            icon="{= ${view>isCancelled} ? 'sap-icon://decline' : 'sap-icon://locked'}"
                                                            visible="{= ${view>isReadOnly} === true}"
                                                            class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{view>tmExpenseCount}" unit="{i18n>tmEntriesUnit}" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'EQ', value1: 'Expense' }], sorter: { path: 'sortDate', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="{i18n>tmColStatus}"/></Column>
                                                                <Column width="14rem" hAlign="Begin"><Text text="{i18n>tmColExpenseType}"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="{i18n>tmColTechnician}"/></Column>
                                                                <Column width="6rem" hAlign="Begin"><Text text="{i18n>tmColExtAmt}"/></Column>
                                                                <Column width="6rem" hAlign="Begin"><Text text="{i18n>tmColIntAmt}"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColDate}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColDecision}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColRemarks}"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'DECLINED_CLOSED' || ${view>decisionStatus} === 'CANCELLED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'REJECTED' : ${view>decisionStatus}}" state="{view>decisionStatusState}"/>
                                                                        <Text text="{view>expenseTypeDisplayText}" wrapping="false"/>
                                                                        <Text text="{view>createPersonDisplayText}" wrapping="false"/>
                                                                        <Input value="{view>externalAmountValue}" type="Number" width="5rem" editable="{view>editMode}"/>
                                                                        <Input value="{view>internalAmountValue}" type="Number" width="5rem" editable="{view>editMode}"/>
                                                                        <Text text="{i18n>unitEuro}"/>
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="8rem" editable="{view>editMode}" maxDate="{path: 'view>entryDateFormatted', formatter: '.formatter.formatTodayMaxDate'}"/>
                                                                        <Text text="{view>decisionRemarks}" wrapping="true"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- MILEAGE TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= ${view>tmMileageCount} > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://car-rental" class="sapUiTinyMarginEnd" color="#6C32A9"/>
                                                        <Title text="{i18n>tmMileage}" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <Button icon="sap-icon://hint" type="Transparent" press=".onShowStatusLegend" tooltip="{i18n>tmStatusLegendTooltip}" class="sapUiTinyMarginBegin"/>
                                                        <Button icon="sap-icon://sort" press=".onOpenSortDialog" tooltip="{i18n>tmSortByTooltip}" class="sapUiTinyMarginBegin">
                                                            <customData>
                                                                <core:CustomData key="tableType" value="Mileage"/>
                                                            </customData>
                                                        </Button>
                                                        <Button text="{i18n>tmEditSelected}" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>mileageEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmDeleteSelected}" icon="sap-icon://delete" type="Reject" press=".onDeleteSelectedTM" visible="{= ${view>mileageEditMode} !== true &amp;&amp; ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmSaveAll}" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>mileageEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmEndEdit}" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>mileageEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="{i18n>tmAddEntry}" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>isReadOnly} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectStatus 
                                                            text="{= ${view>isCancelled} ? ${i18n>activityCancelled} : ${i18n>activityClosed}}" 
                                                            state="{= ${view>isCancelled} ? 'Error' : 'None'}" 
                                                            icon="{= ${view>isCancelled} ? 'sap-icon://decline' : 'sap-icon://locked'}"
                                                            visible="{= ${view>isReadOnly} === true}"
                                                            class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{view>tmMileageCount}" unit="{i18n>tmEntriesUnit}" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'EQ', value1: 'Mileage' }], sorter: { path: 'sortDate', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="{i18n>tmColStatus}"/></Column>
                                                                <Column hAlign="Begin"><Text text="{i18n>tmColMileageType}"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="{i18n>tmColTechnician}"/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="{i18n>tmColDistance}"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="{i18n>tmColDuration}"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="8rem" hAlign="Begin"><Text text="{i18n>tmColDate}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColDecision}"/></Column>
                                                                <Column width="9rem" hAlign="Begin"><Text text="{i18n>tmColRemarks}"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'DECLINED_CLOSED' || ${view>decisionStatus} === 'CANCELLED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'REJECTED' : ${view>decisionStatus}}" state="{view>decisionStatusState}"/>
                                                                        <Text text="{view>mileageTypeDisplayText}"/>
                                                                        <Text text="{view>createPersonDisplayText}"/>
                                                                        <Input value="{view>distanceValue}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Text text="{i18n>unitKilometersUC}"/>
                                                                        <Input value="{view>travelDurationMinutes}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Text text="{i18n>unitMinutes}"/>
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%" editable="{view>editMode}" maxDate="{path: 'view>entryDateFormatted', formatter: '.formatter.formatTodayMaxDate'}"/>
                                                                        <Text text="{view>decisionRemarks}" wrapping="true"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- Empty State -->
                                            <VBox visible="{= ${view>tmReportsCount} === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                                <core:Icon src="sap-icon://document" size="2rem" color="#888"/>
                                                <Text text="{i18n>tmNoEntries}" class="sapUiTinyMarginTop"/>
                                                <Button text="{i18n>tmAddEntry}" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>isReadOnly} !== true}" class="sapUiSmallMarginTop"/>
                                                <ObjectStatus 
                                                    text="{= ${view>isCancelled} ? ${i18n>activityCancelled} : ${i18n>activityClosed}}" 
                                                    state="{= ${view>isCancelled} ? 'Error' : 'None'}" 
                                                    icon="{= ${view>isCancelled} ? 'sap-icon://decline' : 'sap-icon://locked'}"
                                                    visible="{= ${view>isReadOnly} === true}"
                                                    class="sapUiSmallMarginTop"/>
                                            </VBox>
                                        </VBox>
                                    </content>
                                </Panel>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>