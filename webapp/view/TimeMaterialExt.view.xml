<mvc:View
    controllerName="mobileapptm.controller.TimeMaterialExt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <!-- 
        View1: Main view for FSM Service Confirmation application.
        
        Layout Structure:
        1. Service Order Panel (service call header details)
        2. Product Groups (activities grouped by product)
        
        Session context available via footer info button (ℹ️).
        Controller: mobileapptm.controller.View1
    -->
    <Page
        id="mobileAppServiceConfirmationPage"
        showHeader="true"
        showNavButton="false"
        class="sapUiContentPadding"
        busy="{view>/pageLoading}"
        busyIndicatorDelay="0"
    >
        <customHeader>
            <OverflowToolbar design="Info">
                <Image src="./images/TUEV-NORD_Logo.png" height="2rem" class="sapUiTinyMarginEnd customerLogo"/>
                <Title text="{i18n>view1PageTitle} {view>/serviceCall/externalId}" level="H4"/>
            </OverflowToolbar>
        </customHeader>
        <content>
            <layout:VerticalLayout id="mobileAppMainLayout" width="100%" class="sapUiContentPadding">
                
                <!-- Service Order Header -->
                <core:Fragment fragmentName="mobileapptm.view.fragments.ServiceCall" type="XML"/>

                <!-- Activities by Product Group -->
                <VBox id="productGroupsOuterContainer" visible="{view>/organizationSelected}" width="100%">
                    <!-- Loading State -->
                    <VBox visible="{view>/activitiesLoading}" alignItems="Center" justifyContent="Center" class="sapUiLargeMargin">
                        <BusyIndicator size="2rem" class="sapUiSmallMarginBottom"/>
                        <Text text="{i18n>view1LoadingActivities}" class="sapUiTinyMarginTop"/>
                    </VBox>
                    
                    <!-- Content -->
                    <VBox visible="{= !${view>/activitiesLoading} }">
                        <core:Fragment fragmentName="mobileapptm.view.fragments.ProductGroups" type="XML"/>
                    </VBox>
                </VBox>
                
            </layout:VerticalLayout>
        </content>

        <!-- Footer -->
        <footer>
            <OverflowToolbar id="mobileAppFooterToolbar">
                <Button 
                    id="mobileAppTypeConfigButton" 
                    icon="sap-icon://action-settings" 
                    text="{i18n>view1TypeConfig}" 
                    press=".onOpenTypeConfig"
                    tooltip="{i18n>view1TypeConfigTooltip}"
                />
                <Button 
                    id="mobileAppContextInfoButton" 
                    icon="sap-icon://hint" 
                    text="{i18n>view1ContextInfo}" 
                    press=".onShowContextInfo"
                    tooltip="{i18n>view1ContextInfoTooltip}"
                />
                <ToolbarSpacer id="mobileAppFooterSpacer"/>
                <Button id="mobileAppRefreshButton" icon="sap-icon://refresh" text="{i18n>view1Refresh}" press=".onRefresh"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>